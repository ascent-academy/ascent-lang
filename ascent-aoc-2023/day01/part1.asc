import { readLines } from "fs";

fix extractValue = fn(line: String): Int => {
  mut firstDigit = -1;
  mut lastDigit = -1;

  for ch in line.chars() {
    fix digit = ch.toInt() ?? -1;

    if (digit != -1) {
      if (firstDigit != -1) {
        lastDigit = digit;
      } else {
        firstDigit = digit;
        lastDigit = digit;
      };
    };
  };

  firstDigit * 10 + lastDigit;
};

fix lines = try await readLines!("ascent-aoc-2023/day01/part1-input2.txt");

mut sum = 0;

for line in lines {
  fix value = extractValue(line);
  print(value);
  sum = sum + value;
};

sum
