import { readLines } from "fs";

fix extractValue = fn(line: String): Int => {
  mut firstDigit: Int? = None;
  mut lastDigit: Int? = None;

  for ch in line.chars() {
    fix digit = ch.toInt();
    if (digit != None) {
      lastDigit = digit;
      if (firstDigit == None) {
        firstDigit = digit;
      };
    };
  };

  (firstDigit ?? 0) * 10 + (lastDigit ?? 0);
};

fix lines = try await readLines!("ascent-aoc-2023/day01/part1-input2.txt");

mut sum = 0;

for line in lines {
  fix value = extractValue(line);
  sum = sum + value;
};

sum
