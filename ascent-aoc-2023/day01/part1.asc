import { readLines } from "fs";

fix extractValue = (line: String): Int => {
  mut value = 0;

  for ch in line.chars() {
    fix digit = ch.toInt() ?? -1;
    
    if (digit > -1) {
      value = value * 10 + digit;
    };
  };

  value;
}

fix lines = try await readLines!("test-programs/lines.txt");

mut sum = 0;

for line in lines {
  fix value = extractValue(line);
  sum = sum + value;
};

sum
