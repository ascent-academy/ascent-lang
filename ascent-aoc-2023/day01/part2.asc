import { readLines } from "fs";

type Digit = { name: String, value: Int };

fix digits = [
  Digit{ name: "1", value: 1 },
  Digit{ name: "2", value: 2 },
  Digit{ name: "3", value: 3 },
  Digit{ name: "4", value: 4 },
  Digit{ name: "5", value: 5 },
  Digit{ name: "6", value: 6 },
  Digit{ name: "7", value: 7 },
  Digit{ name: "8", value: 8 },
  Digit{ name: "9", value: 9 },
  Digit{ name: "one", value: 1 },
  Digit{ name: "two", value: 2 },
  Digit{ name: "three", value: 3 },
  Digit{ name: "four", value: 4 },
  Digit{ name: "five", value: 5 },
  Digit{ name: "six", value: 6 },
  Digit{ name: "seven", value: 7 },
  Digit{ name: "eight", value: 8 },
  Digit{ name: "nine", value: 9 },
];

fix readDigit = fn(line: String): Int? => {
  for Digit{ name, value } in digits {
    if (line.startsWith(name)) {
      return value;
    };
  };

  None;
};

fix extractValue = fn(line: String): Int => {
  mut firstDigit: Int? = None;
  mut lastDigit: Int? = None;

  mut rest = line;
  
  while (not rest.isEmpty()) {
    fix digit = readDigit(rest);
    if (digit != None) {
      lastDigit = digit;
      if (firstDigit == None) {
        firstDigit = digit;
      };
    };

    rest = rest.drop(1);
  };
    
  (firstDigit ?? 0) * 10 + (lastDigit ?? 0);
};

fix lines = try await readLines!("ascent-aoc-2023/day01/part1-input2.txt");

mut sum = 0;

for line in lines {
  fix value = extractValue(line);
  sum = sum + value;
};

sum
