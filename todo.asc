# todo.asc — a To-Do app written to stress-test the Ascent design.
# Architecture is MVU (§11): a State, update(State, Msg) -> State, view(State) -> Element<Msg>.
#
# Assumed stdlib — NOT yet designed; widget vocabulary is open question §15.2:
#   text      : fn(String) -> Element<Msg>
#   button    : fn(String, Msg) -> Element<Msg>                 # label + message emitted on click
#   checkbox  : fn(Bool, Msg) -> Element<Msg>                   # checked + message emitted on toggle
#   textInput : fn(String, fn(String) -> Msg) -> Element<Msg>   # value + text->message mapper
#   row, column : fn(List<Element<Msg>>) -> Element<Msg>
#   run       : fn(State, fn(State, Msg) -> State, fn(State) -> Element<Msg>) -> Done
# Assumed List methods: .map(f), .filter(p), .append(x), .length()


# ---- Model ----------------------------------------------------------------

type Todo = {
  id: Int,
  title: String,
  done: Bool,
} methods {
  toggled: fn(self) -> Todo => Todo{ ...self, done: not self.done },
};

type Filter = All | Active | Completed
methods {
  matches: fn(self, todo: Todo) -> Bool => match self {
    All       -> true;
    Active    -> not todo.done;
    Completed -> todo.done;
  },
};

type State = {
  todos: List<Todo>,
  draft: String,
  filter: Filter,
  nextId: Int,
} methods {
  addTodo: fn(self) -> State => State{
    ...self,
    todos:  self.todos.append(Todo{ id: self.nextId, title: self.draft, done: false }),
    draft:  "",
    nextId: self.nextId + 1,
  },

  toggleTodo: fn(self, id: Int) -> State => State{
    ...self,
    todos: self.todos.map(fn(t: Todo) -> Todo =>
                if t.id == id { t.toggled() } else { t }),
  },

  deleteTodo: fn(self, id: Int) -> State => State{
    ...self,
    todos: self.todos.filter(fn(t: Todo) -> Bool => t.id != id),
  },

  setDraft: fn(self, text: String) -> State => State{ ...self, draft: text },

  setFilter: fn(self, f: Filter) -> State => State{ ...self, filter: f },

  clearDone: fn(self) -> State => State{
    ...self,
    todos: self.todos.filter(fn(t: Todo) -> Bool => not t.done),
  },

  visibleTodos: fn(self) -> List<Todo> =>
    self.todos.filter(fn(t: Todo) -> Bool => self.filter.matches(t)),

  activeCount: fn(self) -> Int =>
    self.todos.filter(fn(t: Todo) -> Bool => not t.done).length(),
};


# ---- Messages -------------------------------------------------------------

type Msg =
  | Add
  | Toggle{ id: Int }
  | Delete{ id: Int }
  | EditDraft{ text: String }
  | SetFilter{ filter: Filter }
  | ClearCompleted;


# ---- Update ---------------------------------------------------------------
# The message router: a free function (the framework's expected shape).
# Each arm just delegates to a State method that does the real work.
# Add a Msg variant and this match stops compiling until you handle it (§11).

fix update = fn(state: State, msg: Msg) -> State => match msg {
  Add                 -> state.addTodo();
  Toggle{ id }        -> state.toggleTodo(id);
  Delete{ id }        -> state.deleteTodo(id);
  EditDraft{ text }   -> state.setDraft(text);
  SetFilter{ filter } -> state.setFilter(filter);
  ClearCompleted      -> state.clearDone();
};


# ---- View -----------------------------------------------------------------
# Free functions (the render layer). Buttons and checkboxes carry message
# *values*; the input carries a function mapping its text to a message.

fix todoRow = fn(todo: Todo) -> Element<Msg> => row([
  checkbox(todo.done, Toggle{ id: todo.id }),
  text(todo.title),
  button("Delete", Delete{ id: todo.id }),
]);

fix footer = fn(state: State) -> Element<Msg> => row([
  text("{state.activeCount()} left"),
  button("All",             SetFilter{ filter: All }),
  button("Active",          SetFilter{ filter: Active }),
  button("Completed",       SetFilter{ filter: Completed }),
  button("Clear completed", ClearCompleted),
]);

fix view = fn(state: State) -> Element<Msg> => column([
  text("Ascent To-Do"),
  row([
      textInput(state.draft, fn(text: String) -> Msg => EditDraft{ text: text }),
      button("Add", Add),
  ]),
  column(state.visibleTodos().map(todoRow)),
  footer(state),
]);


# ---- Entry ----------------------------------------------------------------

fix initial = State{
  todos:  [],            # type flows in from the field — no annotation needed
  draft:  "",
  filter: All,
  nextId: 1,
};

fix main = fn() -> Done => run(initial, update, view);
