{
  "name": "ascent-lang",
  "displayName": "Ascent Language",
  "description": "Syntax highlighting for the Ascent teaching language",
  "version": "0.1.0",
  "publisher": "ascent-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ascent",
        "aliases": [
          "Ascent",
          "ascent"
        ],
        "extensions": [
          ".asc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ascent",
        "scopeName": "source.ascent",
        "path": "./syntaxes/ascent.tmLanguage.json"
      }
    ]
  }
}
