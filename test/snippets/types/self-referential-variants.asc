# expect: value = same: True, different: False
# A self-referential tagged union: an arithmetic expression is either a number,
# or an addition / multiplication of two smaller expressions. Add and Mul hold
# fields of the very type being declared, so the tree can nest to any depth.
type Expr =
    | Num{ value: Int }
    | Add{ left: Expr, right: Expr }
    | Mul{ left: Expr, right: Expr };

# Build the tree for (1 + 2) * 3, one node at a time.
fix onePlusTwo = Add{ left: Num{ value: 1 }, right: Num{ value: 2 } };
fix formula = Mul{ left: onePlusTwo, right: Num{ value: 3 } };

# Records — and so variants — compare structurally, all the way down: an
# independently rebuilt copy of the same shape is equal to the original.
fix rebuilt = Mul{
    left: Add{ left: Num{ value: 1 }, right: Num{ value: 2 } },
    right: Num{ value: 3 },
};
fix same = formula == rebuilt;

# A different shape (3 * (1 + 2)) is not equal — the tags line up but the
# children differ.
fix flipped = Mul{ left: Num{ value: 3 }, right: onePlusTwo };
fix different = formula == flipped;

# Every Num / Add / Mul value has the one union type, so they sit in one list.
fix forest = [onePlusTwo, formula, rebuilt, flipped];

"same: ${same}, different: ${different}"
